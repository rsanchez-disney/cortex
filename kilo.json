{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "cortex-stream": {
      "type": "remote",
      "url": "http://127.0.0.1:3128/mcp",
      "enabled": true
    },
    "cortex-local": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/Users/example-user/projects/memory-hub",
        "cortex",
        "mcp-server",
        "--mode",
        "stdio",
        "--storage-backend",
        "local",
        "--storage-bucket",
        "./cortex-output"
      ],
      "enabled": true
    }
  },
  "permission": {
    "cortex_find_relevant_services": "allow",
    "cortex_get_service_context": "allow",
    "cortex_list_endpoints": "allow",
    "cortex_get_endpoint_contract": "allow"
  }
}
