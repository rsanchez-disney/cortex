{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "atlas": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/Users/juan.saravia/projects/memory-hub",
        "atlas",
        "mcp-server",
        "--mode",
        "stdio",
        "--storage-backend",
        "local",
        "--storage-bucket",
        "/tmp/atlas-mcp-test"
      ],
      "enabled": true
    }
  },
  "permission": {
    "atlas_find_relevant_services": "allow",
    "atlas_get_service_context": "allow",
    "atlas_list_endpoints": "allow",
    "atlas_get_endpoint_contract": "allow"
  }
}
